button.btn.btn-lg.btn-vk.btn-outline-primary.btn-block.mb-2(
	*ngIf="enableVisitVkButton" (mouseenter)="pony.select()" (mouseout)="pony.reset()" (click)="openLeaveModal()" type="button")
	.vk-logo
		img.pixelart.logo(revSrc="images/logo-vk-small.png")
	| {{'Visit VK!'}}
	.vk-pony
		vk-pony(#pony [scale]="2")

ng-template(#leaveSiteModal)
	leave-site-modal([title]="'Are you sure?'" [link]="vkLink" [buttonLabel]="'Yes, leave'" (close)="closeLeaveModal()" (confirm)="confirmLeave()")

